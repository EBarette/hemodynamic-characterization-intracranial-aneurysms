<?xml version="1.0" encoding="UTF-8" ?>
<!--
  svMultiPhysics input file for 0203_H_CERE_CA – pulsatile physiological run.

  Fluid parameters (validated SimVascular team values):
    Density:    1.06 g/cm³
    Viscosity:  0.04 dyn·s/cm²
    nu:         0.03774 cm²/s  (= 0.04/1.06)
    Inflow:     pulsatile from ICA_extended.flow (0207 ICA waveform, 5 cycles)
                Q_mean = -4.084 cm³/s,  T = 0.95 s
    Outlet:     Out_ICA  Neumann P=0
    Wall:       no-slip rigid

  Inlet area:  0.148037 cm²  →  mean inlet_vel = 2*4.084/0.148037 = 55.18 cm/s

  3800 steps × dt=0.001 s = 3.8 s = 4 cardiac cycles.
  Compare against last cycle (steps 2851–3800).

  ICA_extended.flow is generated by the sbatch script before launch.
  See: jobs/sv_0203_pulsatile.sbatch

  PINN counterpart: conf/pulsatile/config_0203_pulsatile.yaml
-->
<svMultiPhysicsFile version="0.1">

<GeneralSimulationParameters>

  <Continue_previous_simulation> false </Continue_previous_simulation>

  <Number_of_spatial_dimensions> 3 </Number_of_spatial_dimensions>

  <!-- 3800 steps = 4 cardiac cycles at T=0.95 s -->
  <Number_of_time_steps> 7600 </Number_of_time_steps>
  <Time_step_size> 0.0005 </Time_step_size>

  <Spectral_radius_of_infinite_time_step> 0.5 </Spectral_radius_of_infinite_time_step>

  <Searched_file_name_to_trigger_stop> STOP_SIM </Searched_file_name_to_trigger_stop>

  <Save_results_to_VTK_format> 1 </Save_results_to_VTK_format>
  <Name_prefix_of_saved_VTK_files> result </Name_prefix_of_saved_VTK_files>
  <!-- ~50 snapshots per cycle for phase analysis -->
  <Increment_in_saving_VTK_files> 19 </Increment_in_saving_VTK_files>
  <Start_saving_after_time_step> 1 </Start_saving_after_time_step>

  <!-- Restart at each cycle boundary -->
  <Increment_in_saving_restart_files> 1900 </Increment_in_saving_restart_files>
  <Convert_BIN_to_VTK_format> 0 </Convert_BIN_to_VTK_format>

  <Verbose> 1 </Verbose>
  <Warning> 0 </Warning>
  <Debug> 0 </Debug>

</GeneralSimulationParameters>

<Add_mesh name="msh">

  <Mesh_file_path>
    /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-complete.mesh.vtu
  </Mesh_file_path>

  <Add_face name="Inflow_ICA">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-surfaces/Inflow_ICA.vtp
    </Face_file_path>
  </Add_face>

  <Add_face name="Out_ICA">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-surfaces/Out_ICA.vtp
    </Face_file_path>
  </Add_face>

  <Add_face name="walls">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/walls_combined.vtp
    </Face_file_path>
  </Add_face>

</Add_mesh>

<Add_equation type="fluid">

  <Coupled> true </Coupled>

  <Min_iterations> 1 </Min_iterations>
  <Max_iterations> 15 </Max_iterations>
  <Tolerance> 1e-4 </Tolerance>

  <Backflow_stabilization_coefficient> 0.2 </Backflow_stabilization_coefficient>

  <Density> 1.06 </Density>

  <Viscosity model="Constant">
    <Value> 0.04 </Value>
  </Viscosity>

  <Output type="Spatial">
    <Velocity>   true </Velocity>
    <Pressure>   true </Pressure>
    <Traction>   true </Traction>
    <Vorticity>  true </Vorticity>
    <Divergence> true </Divergence>
    <WSS>        true </WSS>
  </Output>

  <Output type="B_INT">
    <Pressure> true </Pressure>
    <Velocity> true </Velocity>
  </Output>

  <LS type="GMRES">
    <Linear_algebra type="fsils">
      <Preconditioner> fsils </Preconditioner>
    </Linear_algebra>
    <Max_iterations>       200  </Max_iterations>
    <Tolerance>            0.01 </Tolerance>
    <Absolute_tolerance>   1e-4 </Absolute_tolerance>
    <Krylov_space_dimension> 100 </Krylov_space_dimension>
  </LS>

  <!--
    Inlet: pulsatile parabolic, Q(t) from ICA_extended.flow (0207 waveform).
    Generated by the sbatch script; covers 4.75 s (5 cardiac cycles).
  -->
  <Add_BC name="Inflow_ICA">
    <Type> Dir </Type>
    <Time_dependence> Unsteady </Time_dependence>
    <Temporal_values_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0207_H_CERE_CA/Simulations/Anr_006V1cgsPulsePres/ICA_extended.flow
    </Temporal_values_file_path>
    <Profile> Parabolic </Profile>
    <Impose_flux> true </Impose_flux>
  </Add_BC>

  <!-- Outlet: zero-traction Neumann → P_ref = 0 -->
  <Add_BC name="Out_ICA">
    <Type> Neu </Type>
    <Time_dependence> Steady </Time_dependence>
    <Value> 0.0 </Value>
  </Add_BC>

  <!-- Wall: no-slip rigid -->
  <Add_BC name="walls">
    <Type> Dir </Type>
    <Time_dependence> Steady </Time_dependence>
    <Value> 0.0 </Value>
  </Add_BC>

</Add_equation>

</svMultiPhysicsFile>
