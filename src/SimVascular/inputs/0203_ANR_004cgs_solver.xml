<!--
  svMultiPhysics input file for 0203_H_CERE_CA – ANR_004cgs simulation.
  Parameters translated from:
    src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/solver.inp
    src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/ANR_004cgs.svpre
  Units: CGS (g, cm, s, dyne)
  Inflow: steady -4.05 cm³/s through Inflow_ICA (parabolic, flux-imposed)
  Outlet: resistance 60122 dyne·s/cm⁵ at Out_ICA
  Wall:   no-slip (rigid) on walls_combined
-->
<svMultiPhysicsFile version="0.1">

<GeneralSimulationParameters>

  <!-- Restart from the last checkpoint (stFile_last.bin = stFile_1480.bin,
       written by the run that crashed at step 1482). The first 1480 steps
       converged correctly; only steps 1481–3000 need to be computed. -->
  <Continue_previous_simulation> true </Continue_previous_simulation>

  <Number_of_spatial_dimensions> 3 </Number_of_spatial_dimensions>

  <!-- solver.inp: Number of Timesteps: 3000, Time Step Size: 0.001 -->
  <Number_of_time_steps> 3000 </Number_of_time_steps>
  <Time_step_size> 0.001 </Time_step_size>

  <!-- solver.inp: Time Integration Rho Infinity: 0.5 (generalised-alpha) -->
  <Spectral_radius_of_infinite_time_step> 0.5 </Spectral_radius_of_infinite_time_step>

  <Searched_file_name_to_trigger_stop> STOP_SIM </Searched_file_name_to_trigger_stop>

  <!-- VTK results saved every 20 steps (matches solver.inp restart interval) -->
  <Save_results_to_VTK_format> 1 </Save_results_to_VTK_format>
  <Name_prefix_of_saved_VTK_files> result </Name_prefix_of_saved_VTK_files>
  <Increment_in_saving_VTK_files> 20 </Increment_in_saving_VTK_files>
  <Start_saving_after_time_step> 1 </Start_saving_after_time_step>

  <!-- solver.inp: Number of Timesteps between Restarts: 20 -->
  <Increment_in_saving_restart_files> 20 </Increment_in_saving_restart_files>
  <Convert_BIN_to_VTK_format> 0 </Convert_BIN_to_VTK_format>

  <Verbose> 1 </Verbose>
  <Warning> 0 </Warning>
  <Debug> 0 </Debug>

</GeneralSimulationParameters>

<!-- ================================================================
     Mesh – paths are absolute so the solver can be run from any CWD
     ================================================================ -->
<Add_mesh name="msh">

  <Mesh_file_path>
    /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-complete.mesh.vtu
  </Mesh_file_path>

  <!-- Inflow cap (svpre: prescribed_velocities_vtp, surface ID 2) -->
  <Add_face name="Inflow_ICA">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-surfaces/Inflow_ICA.vtp
    </Face_file_path>
  </Add_face>

  <!-- Outlet cap (svpre: pressure_vtp / resistance, surface ID 3) -->
  <Add_face name="Out_ICA">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/mesh-surfaces/Out_ICA.vtp
    </Face_file_path>
  </Add_face>

  <!-- Vessel wall (svpre: noslip_vtp mesh-complete/walls_combined.vtp) -->
  <Add_face name="walls">
    <Face_file_path>
      /home/ucl/elen/ebarette/src/SimVascular/0203_H_CERE_CA/Simulations/ANR_004cgs/mesh-complete/walls_combined.vtp
    </Face_file_path>
  </Add_face>

</Add_mesh>

<!-- ================================================================
     Fluid equation (incompressible Navier-Stokes, NS svLS solver)
     ================================================================ -->
<Add_equation type="fluid">

  <!-- solver.inp: Step Construction: 0 1 0 1 → coupled NS -->
  <Coupled> true </Coupled>

  <!-- Min_iterations=1: the definitive fix for the "Singular matrix detected"
       crash that occurs deterministically as the simulation approaches steady
       state (~step 1440+).

       Root cause (confirmed from run output):
         - Around step 1440 the solution converges to machine precision:
           Ri/R0 at Newton iter 1 drops to ~1e-11.
         - With Min_iterations≥2 Newton is forced into iter 2, which calls
           FSILS with a residual ~3e-14.  At that scale the Krylov vectors
           built by ns_solver are linearly dependent → ge::ge() (3×3 Gauss
           elimination on the Krylov subspace) returns false → crash.
         - Previous attempts: Min_iterations=3 crashed at step 1310;
           Min_iterations=2 delayed the crash to step 1482.

       With Min_iterations=1:
         - After iter 1 (which always succeeds, lsIt=0–1), the convergence
           check Ri/R0 < Tolerance (1e-11 << 1e-3) is satisfied AND
           iter ≥ min_iters=1 → Newton terminates without calling FSILS again.
         - Early steps (1–~1440) are completely unaffected: their Ri/R0 at
           iter 1 is >> 1e-3 so they still run 3–5 Newton iterations as before.
         - Steps 1481–3000 each run 1 cheap Newton iteration (lsIt=0 or 1)
           since the solution no longer changes at machine precision. -->
  <Min_iterations> 1 </Min_iterations>

  <!-- solver.inp: Maximum Number of Iterations for svLS NS Solver: 10
       (outer Newton iterations)                                        -->
  <Max_iterations> 10 </Max_iterations>

  <!-- solver.inp: Residual Criteria: 0.001 -->
  <Tolerance> 1e-3 </Tolerance>

  <!-- solver.inp: Backflow Stabilization Coefficient: 0.2 -->
  <Backflow_stabilization_coefficient> 0.2 </Backflow_stabilization_coefficient>

  <!-- solver.inp: Density: 1.06 g/cm³ -->
  <Density> 1.06 </Density>

  <!-- solver.inp: Viscosity: 0.04 dyne·s/cm² (Newtonian) -->
  <Viscosity model="Constant">
    <Value> 0.04 </Value>
  </Viscosity>

  <!-- Spatial VTK output fields -->
  <Output type="Spatial">
    <Velocity>   true </Velocity>
    <Pressure>   true </Pressure>
    <Traction>   true </Traction>
    <Vorticity>  true </Vorticity>
    <Divergence> true </Divergence>
    <WSS>        true </WSS>
  </Output>

  <!-- Boundary-integrated output (average pressure, flow rates) -->
  <Output type="B_INT">
    <Pressure> true </Pressure>
    <Velocity> true </Velocity>
  </Output>

  <!-- LS solver: GMRES (monolithic GMRES replaces the NS block solver).
       REASON: The NS block solver crashes deterministically at step ~1773.
       ns_solver.cpp builds a 2x2 Krylov Gram matrix on its first outer
       iteration.  When Rm approaches 0 (machine precision ~5e-13), MU0=G*P
       and MU1=Rm-G*P become antiparallel, det(Gram) falls below machine_eps,
       ge::ge(N=2) returns false, and the master MPI rank throws.  This is
       unavoidable in the NS code path regardless of Min_iterations.

       GMRES fix: gmres_v() has a pre-loop early exit (gmres.cpp line 469):
         if (ls.iNorm less-than-or-equal absTol) { return; }
       ge() is never called.  With absTol=1e-3 and the preconditioned residual
       at steps 1761-3000 being ~1e-12..1e-10 (well below 1e-3), gmres_v
       returns immediately with a near-zero Newton update.  The solution does
       not change (it is already at steady state since step ~1440) and Newton
       convergence (Ri/R0 ~5e-13 much less than tol=1e-3) is confirmed.

       NS-specific parameters (NS_GM_max_iterations, NS_CG_max_iterations,
       NS_GM_tolerance, NS_CG_tolerance) are removed; they are only parsed
       for solver_type=NS and would be silently ignored for GMRES. -->
  <LS type="GMRES">
    <Linear_algebra type="fsils">
      <Preconditioner> fsils </Preconditioner>
    </Linear_algebra>
    <Max_iterations>       100  </Max_iterations>
    <Tolerance>            0.05 </Tolerance>
    <Absolute_tolerance>   1e-3 </Absolute_tolerance>
    <Krylov_space_dimension> 100 </Krylov_space_dimension>
  </LS>

  <!-- Inflow BC: steady parabolic profile, flux imposed
       solver.inp/sjb: prescribed velocities, parabolic, flow = -4.05 cm³/s
       (Inflow_ICA.flow has two identical points → effectively steady)  -->
  <Add_BC name="Inflow_ICA">
    <Type> Dir </Type>
    <Time_dependence> Steady </Time_dependence>
    <Profile> Parabolic </Profile>
    <Impose_flux> true </Impose_flux>
    <!-- Negative value = flux into domain through outward normal -->
    <Value> -4.05 </Value>
  </Add_BC>

  <!-- Outlet BC: resistance (implicit pressure coupling)
       solver.inp: Resistance Values: 60122 dyne·s/cm⁵
       solver.inp: Pressure Coupling: Implicit → Resistance time dependence -->
  <Add_BC name="Out_ICA">
    <Type> Neu </Type>
    <Time_dependence> Resistance </Time_dependence>
    <Value> 60122 </Value>
  </Add_BC>

  <!-- Wall BC: no-slip (rigid wall, solver.inp/sjb: rigid) -->
  <Add_BC name="walls">
    <Type> Dir </Type>
    <Time_dependence> Steady </Time_dependence>
    <Value> 0.0 </Value>
  </Add_BC>

</Add_equation>

</svMultiPhysicsFile>
